{
  "name": "@yachiyo/desktop",
  "version": "1.4.1",
  "private": true,
  "description": "Yachiyo desktop app",
  "main": "./out/main/index.js",
  "bin": {
    "yachiyo": "bin/yachiyo"
  },
  "scripts": {
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:export": "drizzle-kit export --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:introspect": "drizzle-kit introspect --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:up": "drizzle-kit up --config drizzle.config.ts",
    "native:abi": "node -p \"'node=' + process.version + ' modules=' + process.versions.modules\" && ELECTRON_RUN_AS_NODE=1 electron -p \"'electron=' + process.versions.electron + ' node=' + process.versions.node + ' modules=' + process.versions.modules\"",
    "native:prepare": "node ../../scripts/ensure-electron-native-deps.mjs",
    "native:rebuild": "pnpm exec electron-rebuild -f -w better-sqlite3",
    "external-hooks:build": "node ../../scripts/build-external-hooks.mjs",
    "sync-core:build": "node ../../scripts/build-sync-core.mjs",
    "search:download": "node ../../scripts/download-search-binaries.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:node-tests": "tsc --noEmit -p tsconfig.node.tests.json --composite false",
    "typecheck:web-tests": "tsc --noEmit -p tsconfig.web.tests.json --composite false",
    "typecheck:tests": "pnpm run typecheck:node-tests && pnpm run typecheck:web-tests",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "test:server:native": "pnpm run typecheck:tests && pnpm run native:prepare && ELECTRON_RUN_AS_NODE=1 electron --experimental-strip-types --test ../../packages/runtime/src/storage/sqlite/*.native.test.ts",
    "start": "pnpm run native:prepare && electron-vite preview",
    "dev": "node ../../scripts/run-desktop-dev.mjs",
    "dev:channels": "node ../../scripts/run-desktop-dev.mjs --channels",
    "dev:schedules": "node ../../scripts/run-desktop-dev.mjs --schedules",
    "build": "pnpm run native:prepare && pnpm run search:download && pnpm run sync-core:build && pnpm run typecheck && electron-vite build && node ../../scripts/stage-runtime-node-modules.mjs",
    "build:unpack": "pnpm run external-hooks:build && pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run external-hooks:build && pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip",
    "build:linux": "pnpm run build && electron-builder --linux",
    "postinstall": "node -e \"console.log('Skipping Electron native rebuild on install. Run pnpm run native:prepare before Electron runtime or native sqlite tests, or pnpm run native:rebuild to force a rebuild.')\""
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.0",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/gateway": "^3.0.66",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/google-vertex": "^4.0.95",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.19",
    "@chenglou/pretext": "^0.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@lobehub/icons": "^5.6.0",
    "@opentelemetry/api": "^1.9.0",
    "@standard-schema/spec": "^1.1.0",
    "@streamdown/code": "^1.1.1",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.25",
    "@vercel/oidc": "^3.1.0",
    "@yachiyo/cli": "workspace:*",
    "@yachiyo/core-skills": "workspace:*",
    "@yachiyo/i18n": "workspace:*",
    "@yachiyo/runtime": "workspace:*",
    "@yachiyo/shared": "workspace:*",
    "ai": "^6.0.174",
    "better-sqlite3": "^12.8.0",
    "compromise": "^14.15.0",
    "cron-parser": "^5.5.0",
    "defuddle": "^0.14.0",
    "diff": "^9.0.0",
    "discord.js": "^14.25.1",
    "drizzle-orm": "^0.45.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "eventsource-parser": "^3.0.6",
    "framer-motion": "^12.38.0",
    "htmlparser2": "^12.0.0",
    "ignore": "^7.0.5",
    "jieba-wasm": "^2.4.0",
    "json-schema": "^0.4.0",
    "katex": "^0.16.44",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.577.0",
    "match-sorter": "^8.2.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "remark-cjk-friendly": "^2.3.1",
    "remark-cjk-friendly-gfm-strikethrough": "^2.3.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "smol-toml": "^1.6.1",
    "stopword": "^3.1.5",
    "streamdown": "^2.5.0",
    "telegraf": "^4.16.3",
    "undici": "^8.7.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "unpdf": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/stopword": "^2.0.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.2.6"
  }
}
