{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/translator/env.d.ts",
    "src/renderer/jotdown/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/renderer/settings/**/*",
    "src/renderer/translator/**/*",
    "src/renderer/jotdown/**/*",
    "src/preload/*.d.ts",
    "../../packages/shared/src/**/*"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["node", "react", "react-dom", "vite/client"],
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@yachiyo/shared/*": ["../../packages/shared/src/*"]
    }
  }
}
