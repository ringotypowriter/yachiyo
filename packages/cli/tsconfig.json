{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": false,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@yachiyo/runtime/*": ["../runtime/src/*"],
      "@yachiyo/shared/*": ["../shared/src/*"]
    }
  }
}
