{
  "name": "@yachiyo/cli",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "yachiyo": "bin/yachiyo"
  },
  "exports": {
    "./yachiyoCli": "./src/yachiyoCli.ts"
