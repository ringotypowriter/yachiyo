{
  "name": "yachiyo",
  "version": "1.0.0",
  "description": "Yachiyo",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "22.22.1",
    "pnpm": ">=10 <11"
  },
  "bin": {
    "yachiyo": "bin/yachiyo"
  },
  "author": "Ringo",
  "homepage": "https://github.com/ringotypowriter/yachiyo",
  "scripts": {
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:export": "drizzle-kit export --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:introspect": "drizzle-kit introspect --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:up": "drizzle-kit up --config drizzle.config.ts",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "native:abi": "node -p \"'node=' + process.version + ' modules=' + process.versions.modules\" && ELECTRON_RUN_AS_NODE=1 electron -p \"'electron=' + process.versions.electron + ' node=' + process.versions.node + ' modules=' + process.versions.modules\"",
    "native:rebuild": "node scripts/ensure-electron-native-deps.mjs",
    "test:server": "node scripts/run-server-tests.mjs",
    "test:server:native": "pnpm run native:rebuild && ELECTRON_RUN_AS_NODE=1 electron --experimental-strip-types --test src/main/yachiyo-server/storage/sqlite/sqlite.native.test.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "pnpm run native:rebuild && electron-vite preview",
    "dev": "pnpm run native:rebuild && (electron-vite dev; tput reset)",
    "build": "pnpm run native:rebuild && pnpm run typecheck && electron-vite build",
    "postinstall": "node -e \"console.log('Skipping Electron native rebuild on install. Run pnpm run native:rebuild before Electron runtime or native sqlite tests.')\"",
    "build:unpack": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip",
    "build:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.0",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/gateway": "^3.0.66",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/google-vertex": "^4.0.95",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.19",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/better-sqlite3": "^7.6.13",
    "@vercel/oidc": "^3.1.0",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.8.0",
    "defuddle": "^0.14.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eventsource-parser": "^3.0.6",
    "htmlparser2": "^12.0.0",
    "ignore": "^7.0.5",
    "json-schema": "^0.4.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.577.0",
    "streamdown": "^2.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ]
  }
}
